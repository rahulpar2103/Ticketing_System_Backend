DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/ticketing_db
TEST_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/ticketing_test
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DEBUG=true
SECRET_KEY=replace-with-output-of-python-c-import-secrets-print-secrets-token-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=300
REDIS_URL=redis://localhost:6379

# AWS S3 Settings
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name

# AWS SES SMTP Settings
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-ses-smtp-username
SMTP_PASSWORD=your-ses-smtp-password
MAIL_FROM=your-verified-email@example.com
